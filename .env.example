# GitHub personal access token (required for PR reviews)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Google Gemini API key (required for AI analysis)
# Generate at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (optional, default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Log level (optional, default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Maximum file size in characters to send for review (optional, default: 50000)
MAX_FILE_SIZE=50000

# Request timeout in seconds (optional, default: 30)
REQUEST_TIMEOUT=30

# Maximum retry attempts for API calls (optional, default: 3)
MAX_RETRIES=3
